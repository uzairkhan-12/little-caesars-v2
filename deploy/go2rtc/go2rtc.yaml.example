# go2rtc config — RTSP -> browser bridge for HD camera feeds.
#
# Copy this file to go2rtc.yaml (gitignored — it holds real camera credentials,
# never commit it) and fill in your actual RTSP URLs.
#
# Run this on the Proxmox host (or an LXC/container on the same LAN as the
# cameras). It stays off the public internet; the little-caesars-v2 app
# reaches it over the local network/docker network and proxies it through
# /api/rtsp/$entity, which is behind the app's login gate.
#
# Stream names here ("cam1", "cam2") must match RTSP_CAMERAS ids in the app's .env.
#
# IMPORTANT: the RTSP path is often named "h264Preview_..." for historical/
# compatibility reasons even when the camera is actually configured to encode
# H.265/HEVC (common on newer Reolink firmware — check Settings > Display >
# Encode format on the camera itself if unsure). Either way, go2rtc's MJPEG
# endpoint (/api/stream.mjpeg) needs an actual MJPEG track — it can't produce
# one from H.264 or H.265 alone. The second `ffmpeg:` line below adds an
# on-demand (lazy — only runs while someone is viewing) FFmpeg transcode to
# MJPEG; without it you'll see "codecs not matched" errors in the go2rtc logs
# and empty stream.mjpeg responses. `width=1920` caps the transcode to 1080p
# to keep CPU usage reasonable — drop it if you want native 4K and have the
# CPU headroom (or the cores to spare for hardware accel; see
# https://github.com/AlexxIT/go2rtc/blob/master/internal/ffmpeg/hardware/README.md).
streams:
  cam1:
    - rtsp://admin:your-password@192.168.5.21:554/h264Preview_01_main
    - ffmpeg:cam1#video=mjpeg#width=1920
  cam2:
    - rtsp://admin:your-password@192.168.5.20:554/h264Preview_01_main
    - ffmpeg:cam2#video=mjpeg#width=1920

api:
  # Bind to all interfaces inside its own container/network; keep this port
  # closed on any public-facing firewall/router — only the app should reach it.
  listen: ":1984"

# Uncomment to also allow WebRTC (lower latency than MJPEG) if you later add
# a WebRTC player in the app instead of the <img> MJPEG tiles.
# webrtc:
#   listen: ":8555/tcp"
