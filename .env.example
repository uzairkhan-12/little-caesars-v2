# Copy to `.env` and fill in the values, then run `bun install && bun run dev`.
# All variables are server-side only (read via process.env in server functions
# / server routes). None are exposed to the browser.

# --- Gate / login (required) -------------------------------------------------
# Credentials the /login page checks against.
SITE_USERNAME=admin
SITE_PASSWORD=change-me

# Secret used to sign the session cookie. Use a long random string (32+ chars).
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# --- LC Logic backend (required for dashboard + statistics) ------------------
# Base URL of the lclogic API that powers /api/counts, /api/today, etc.
LCLOGIC_URL=https://lclogic2.primewave2.tech

# --- Home Assistant (required for camera + HA websocket routes) --------------
# Base URL of your Home Assistant instance (no trailing slash).
HOME_ASSISTANT_URL=https://your-home-assistant.example.com
# Long-lived access token from HA -> Profile -> Security -> Long-Lived Access Tokens.
HOME_ASSISTANT_TOKEN=your-long-lived-access-token
